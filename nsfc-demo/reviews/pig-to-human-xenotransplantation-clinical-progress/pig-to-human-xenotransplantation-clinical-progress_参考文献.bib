  title = {Xenotransplantation: from proof of concept to clinical reality},
  author = {Xiaowei Hu and David K C Cooper and Dela Golshayan and Carmen Gonelle‐Gispert and Hans Hirsch and Alban Longchamp and Raphael P H Meier and Philippe Morel and Nicolas J Mueller and Yannick D. Müller},
